// =============================================================================
// DERA School System — Prisma Schema
// Generated by Builder AI from spec files in examples/school/
// Source of truth: student_entity.dera, student_events.dera
// Tech stack: tech-stack.md → PostgreSQL + Prisma
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// CATALOGS — Enums derived from student_entity.dera Catalogs section
// =============================================================================

enum Grade {
  First
  Second
  Third
  Fourth
  Fifth
  Sixth
}

enum Group {
  A
  B
  C
}

// =============================================================================
// STATE DIMENSIONS — Enums derived from student_entity.dera States section
// =============================================================================

enum AcademicState {
  Active
  Graduated
  Suspended
  Expelled
}

// =============================================================================
// PART 2 — Persistence (Domain Data)
// The permanent source of truth for the Student entity.
// Schema fields from student_entity.dera Schema section.
// State dimensions from student_entity.dera States section.
// Retention: PERMANENT — never purged.
// =============================================================================

model Student {
  id                     String         @id @default(uuid()) @map("student_id")
  name                   String         @map("name")
  lastName               String         @map("last_name")
  grade                  Grade          @map("grade")
  group                  Group          @map("group")
  dateOfBirth            DateTime       @map("date_of_birth") @db.Date

  // State dimensions — evaluated by rules engine at runtime
  academicState          AcademicState  @default(Active) @map("academic_state")

  // DERA standard audit fields
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  createdByEventId       String         @map("created_by_event_id")
  lastModifiedByEventId  String         @map("last_modified_by_event_id")

  @@map("students")
}

// =============================================================================
// PART 1 — EventRequests
// Stores every incoming request. Used for idempotency, traceability,
// and bug reproduction. EventInput stores full payload for exact reproduction.
// Retention: 3–12 months.
// =============================================================================

enum EventRequestStatus {
  Received
  Processing
  Completed
  Failed
}

model EventRequest {
  id            String               @id @default(uuid()) @map("event_id")
  traceId       String               @map("trace_id")
  correlationId String               @map("correlation_id")
  actorId       String               @map("actor_id")
  eventType     String               @map("event_type")
  entityId      String?              @map("entity_id")   // null for NewEntry events
  eventInput    Json                 @map("event_input")  // full payload for bug reproduction
  status        EventRequestStatus   @default(Received)
  receivedAt    DateTime             @default(now()) @map("received_at")
  completedAt   DateTime?            @map("completed_at")

  // Relations
  eventResult   EventResult?
  changeLogs    ChangeLog[]
  errorLogs     ErrorLog[]

  @@map("event_requests")
}

// =============================================================================
// PART 3 — ChangeLog
// Immutable audit trail. One record per field changed per event.
// Tracks who changed what, when, and which event caused it.
// Retention: 3–12 months (permanent for regulated domains).
// =============================================================================

model ChangeLog {
  id          String   @id @default(uuid()) @map("change_id")
  eventId     String   @map("event_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  field       String   @map("field")
  oldValue    String?  @map("old_value")
  newValue    String   @map("new_value")
  changedAt   DateTime @default(now()) @map("changed_at")
  actorId     String   @map("actor_id")

  // Relations
  event       EventRequest @relation(fields: [eventId], references: [id])

  @@map("change_log")
}

// =============================================================================
// PART 4 — EventResults
// The structured outcome of every event execution.
// Used for idempotency (return stored result if same EventId arrives again)
// and as the response payload returned to the actor.
// Retention: 3–12 months.
// =============================================================================

enum EventOutcome {
  Success
  ValidationFailure
  NoAction
  SystemError
}

model EventResult {
  id                 String        @id @default(uuid()) @map("result_id")
  eventId            String        @unique @map("event_id")
  outcome            EventOutcome
  code               String        @map("code")
  message            String        @map("message")
  data               Json?         @map("data")             // ActionResult payload
  failedValidations  Json?         @map("failed_validations") // [{field, code, message}]
  warnings           Json?         @map("warnings")          // [{code, message}]
  traceId            String        @map("trace_id")
  executedAt         DateTime      @default(now()) @map("executed_at")
  durationMs         Int           @map("duration_ms")

  // Relations
  event              EventRequest  @relation(fields: [eventId], references: [id])

  @@map("event_results")
}

// =============================================================================
// PART 5 — ErrorLog
// Technical errors during execution. Separate from ChangeLog.
// Primary data source for Monitor AI.
// Retention: 1–6 months. Resolved errors purged sooner.
// =============================================================================

model ErrorLog {
  id             String    @id @default(uuid()) @map("error_id")
  eventId        String?   @map("event_id")
  errorType      String    @map("error_type")
  errorMessage   String    @map("error_message")
  stackTrace     String    @map("stack_trace") @db.Text
  serviceName    String    @map("service_name")
  entityType     String?   @map("entity_type")
  entityId       String?   @map("entity_id")
  environment    String    @map("environment")
  occurredAt     DateTime  @default(now()) @map("occurred_at")
  resolved       Boolean   @default(false) @map("resolved")
  resolvedByBug  String?   @map("resolved_by_bug")   // references /triage/BUG-XXX
  resolvedAt     DateTime? @map("resolved_at")

  // Relations
  event          EventRequest? @relation(fields: [eventId], references: [id])

  @@map("error_log")
}
